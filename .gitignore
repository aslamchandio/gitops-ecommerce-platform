# Env
.env
*.local

# Java
target/
*.class
.gradle/
build/

# Node
node_modules/
npm-debug.log*

# Go
*.exe
*.test
vendor/

# IDE
.idea/
.vscode/
*.iml

# Terraform
.terraform/
# Provider-version lock file — local to each contributor's `terraform init`
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfvars
!terraform.tfvars.example
# terraform.auto.tfvars is committed: terraform auto-loads it as defaults
# for CI / shared use, while a local terraform.tfvars (gitignored, for
# personal overrides like master_authorized_networks) still wins via
# variable precedence.
!terraform.auto.tfvars
# Plan files contain rendered values including sensitive ones — never commit
tfplan
*.tfplan

# ArgoCD deploy keys — private key MUST NOT be committed
infrastructure/terraform/.argocd-deploy-key
infrastructure/terraform/.argocd-deploy-key.pub

# Generated images (regenerate with script)
services/ui-service/src/main/resources/static/images/products/*.png

# Terraform-rendered K8s manifest (contains project-specific IPs, IDs)
# Re-created on every `terraform apply` from secrets.tf
k8s/generated-config.yaml

# OS
.DS_Store
Thumbs.db
tfplan
tfplan-*
# Broader catch-all for any key-file variant (.bak, .compromised, .old, etc.)
infrastructure/terraform/.argocd-deploy-key*
